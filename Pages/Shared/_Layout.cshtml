@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "/Index";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — Music Downloader</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;900&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true">
</head>
<body>
    <header class="app-header">
        <div class="header-inner">
            <span class="app-brand">🎵 Music Downloader</span>
            <nav class="app-nav">
                <a href="/Index" class="nav-link @(currentPage == "/Index" ? "active" : "")">📊 Spotify</a>
                <a href="/YtMusic" class="nav-link @(currentPage == "/YtMusic" ? "active" : "")">🎵 YT Music</a>
            </nav>
            <a href="/Settings" class="nav-settings-btn @(currentPage == "/Settings" ? "active" : "")" title="Settings">⚙️</a>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    @RenderSection("Scripts", required: false)
</body>
</html>
