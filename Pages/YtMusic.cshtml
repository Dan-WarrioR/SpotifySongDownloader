@page
@model SpotifyDownloader.Pages.YtMusicModel
@{
    ViewData["Title"] = "YT Music";
}

<div class="container">
    <div class="card">
        <h2 class="card-title">Current Setup</h2>

        <div class="info-grid">
            <div class="info-box">
                <div class="info-label">Playlists</div>
                <div class="info-value" id="ytmInfoPlaylistCount">0</div>
                <div class="info-value text list empty" id="ytmInfoPlaylistList" style="margin-top: 8px;"></div>
            </div>
            <div class="info-box">
                <div class="info-label">Download Folder</div>
                <div class="info-value text empty" id="ytmInfoDownloadFolder">Not configured</div>
                <button class="btn-secondary" onclick="openFolder()" style="margin-top: 8px; font-size: 0.8rem; padding: 4px 10px;">📂 Open</button>
            </div>
            <div class="info-box">
                <div class="info-label">Auth</div>
                <div class="info-value text" id="ytmInfoAuth">None (public)</div>
            </div>
            <div class="info-box">
                <div class="info-label">Total Downloaded</div>
                <div class="info-value" id="ytmInfoTotalDownloaded">0</div>
            </div>
        </div>

        <div class="tools-check">
            <div style="flex: 1; font-weight: 600; color: var(--text-secondary);">Required Tools:</div>
            <div class="tool-status" id="ytdlpStatus"><span>yt-dlp</span></div>
            <button id="updateYtdlpBtn" class="btn-secondary" onclick="updateYtDlp()" style="font-size: 0.8rem; padding: 4px 10px;">⬆️ Update</button>
            <div class="tool-status" id="ffmpegStatus"><span>ffmpeg</span></div>
        </div>
    </div>

    <div class="card">
        <h2 class="card-title">Download Playlists</h2>

        <div id="ytmStatusMessage"></div>
        <button id="ytmDownloadBtn" class="btn-download" disabled><span>⬇️ Download All Playlists</span></button>

        <div id="ytmProgressSection" class="progress-section">
            <div class="current-track" id="ytmCurrentTrack"></div>
            <div class="progress-text" id="ytmProgressText">0%</div>
            <div class="progress-bar-container">
                <div class="progress-bar" id="ytmProgressBar"></div>
            </div>
            <div class="stats">
                <div class="stat">
                    <div class="stat-value" id="ytmCompletedCount">0</div>
                    <div class="stat-label">Completed</div>
                </div>
                <div class="stat">
                    <div class="stat-value" id="ytmFailedCount">0</div>
                    <div class="stat-label">Failed</div>
                </div>
                <div class="stat">
                    <div class="stat-value" id="ytmTotalCount">0</div>
                    <div class="stat-label">Total</div>
                </div>
            </div>
            <button id="ytmCancelBtn" class="btn-danger" onclick="cancelYtmDownload()" style="display: none; margin-top: 12px; width: 100%;">✕ Cancel Download</button>
            <div id="ytmResultsList" class="results-list"></div>
        </div>

        <div class="danger-zone">
            <h3>⚠️ Re-download All Tracks</h3>
            <p>Clears the shared download history (affects Spotify and YT Music). Use this to force re-download of all tracks.</p>
            <button id="ytmClearHistoryBtn" class="btn-danger">🔄 Clear History & Re-download All</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ytmusic.js"></script>
}
